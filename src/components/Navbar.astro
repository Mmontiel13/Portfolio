<nav class="navbar content-object">
  <a href="#inicio" class="nav-link">Principal</a>
  <span class="separator"><i class="fa-solid fa-diamond"></i></span>

  <a href="#proyectos" class="nav-link">Proyectos</a>
  <span class="separator"><i class="fa-solid fa-diamond"></i></span>

  <a href="#contacto" class="nav-link">Contacto</a>
</nav>

<style>

  .navbar {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 10px 25px;
    display: flex;
    align-items: center;
    gap: 25px;
    border-radius: 999px;
    z-index: 9999;
    background: rgba(15, 15, 15, 0.4);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(217, 217, 217, 0.1);
  }

  .navbar a,
  .navbar .separator {
    color: rgba(217, 217, 217, 0.6);
    text-decoration: none;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .navbar .separator {
    cursor: default;
    font-size: 8px;
    display: flex;
    align-items: center;
  }

  /* Hover y Estado Activo */
  .navbar a:hover,
  .navbar a.active {
    color: rgba(217, 217, 217, 1);
    text-shadow: 0 0 8px rgba(217, 217, 217, 0.4);
  }
</style>

<script>
  // Lógica de IntersectionObserver para detectar la sección activa
  const observerOptions = {
    root: null,
    rootMargin: '-30% 0px -60% 0px', // Ajustado para activar el link cuando la sección está al centro
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        document.querySelectorAll('.nav-link').forEach(link => {
          // Compara el href del link con el ID de la sección actual
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, observerOptions);

  // Observa todas las secciones que tengan un ID
  document.querySelectorAll('section[id]').forEach(section => observer.observe(section));
</script>