<nav class="navbar content-object">
  <a href="#inicio" class="nav-link">Principal</a>
  <span class="separator"><i class="fa-solid fa-diamond"></i></span>
  
  <a href="#proyectos" class="nav-link">Proyectos</a>
  <span class="separator"><i class="fa-solid fa-diamond"></i></span>
  
  <a href="#contacto" class="nav-link">Contacto</a>
  <span class="separator"><i class="fa-solid fa-diamond"></i></span>
  
  <a href="#" class="lang-btn"><i class="fa-solid fa-language fa-xl"></i></a>
</nav>

<style>
/* Asegura que el scroll no sea brusco al dar click */
html {
  scroll-behavior: smooth;
}

.navbar {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translateX(-50%);
  padding: 10px 25px;
  display: flex;
  align-items: center; /* Alinea iconos y texto */
  gap: 25px;
  border-radius: 999px;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.2); /* Opcional: fondo para legibilidad */
  backdrop-filter: blur(10px);
}

/* Estilo base para enlaces y separadores */
.navbar a, 
.navbar .separator {
  color: rgba(217, 217, 217, 0.6);
  text-decoration: none;
  font-size: 14px;
  transition: color 0.3s ease;
}

/* El separador no es clickeable pero mantiene el color */
.navbar .separator {
  cursor: default;
  font-size: 12px; /* Ajusta el tamaño del diamante si es necesario */
}

/* Hover y Clase Activa */
.navbar a:hover,
.navbar a.active {
  color: rgba(217, 217, 217, 1);
}
</style>

<script>
  // Esta lógica se ejecuta en el cliente
  const observerOptions = {
    root: null,
    rootMargin: '-30% 0px -60% 0px', // Detecta la sección cuando está en el centro
    threshold: 0
  };

  const handleIntersect = (entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        const navLinks = document.querySelectorAll('.nav-link');
        
        navLinks.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('href') === `#${id}`) {
            link.classList.add('active');
          }
        });
      }
    });
  };

  const observer = new IntersectionObserver(handleIntersect, observerOptions);

  // Seleccionamos todas las secciones de tu página
  // Asegúrate de que tus secciones tengan id="inicio", id="proyectos", etc.
  document.querySelectorAll('section[id]').forEach(section => {
    observer.observe(section);
  });
</script>