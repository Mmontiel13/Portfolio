<nav class="navbar content-object">
  <a href="#inicio" class="nav-link">Principal</a>
  <span class="separator"><i class="fa-solid fa-diamond"></i></span>

  <a href="#proyectos" class="nav-link">Proyectos</a>
  <span class="separator"><i class="fa-solid fa-diamond"></i></span>

  <a href="#contacto" class="nav-link">Contacto</a>
</nav>

<style>

  .navbar {
    position: fixed;
    top: clamp(12px, 3vw, 20px);
    left: 50%;
    transform: translateX(-50%);
    padding: clamp(8px, 2vw, 10px) clamp(16px, 4vw, 25px);
    display: flex;
    align-items: center;
    gap: clamp(12px, 3vw, 25px);
    border-radius: 999px;
    z-index: 9999;
    background: rgba(15, 15, 15, 0.4);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(217, 217, 217, 0.1);
    max-width: 90vw;
    flex-wrap: wrap;
    justify-content: center;
  }

  .navbar a,
  .navbar .separator {
    color: rgba(217, 217, 217, 0.6);
    text-decoration: none;
    font-size: clamp(12px, 2.5vw, 14px);
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .navbar .separator {
    cursor: default;
    font-size: clamp(6px, 1.5vw, 8px);
    display: flex;
    align-items: center;
  }

  /* Hover y Estado Activo */
  .navbar a:hover,
  .navbar a.active {
    color: rgba(217, 217, 217, 1);
    text-shadow: 0 0 8px rgba(217, 217, 217, 0.4);
  }

  @media (max-width: 480px) {
    .navbar .separator {
      display: none;
    }

    .navbar {
      gap: clamp(8px, 2vw, 12px);
    }
  }
</style>

<script>

  const observerOptions = {
    root: null,
    rootMargin: '-30% 0px -60% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        document.querySelectorAll('.nav-link').forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, observerOptions);

  document.querySelectorAll('section[id]').forEach(section => observer.observe(section));
</script>