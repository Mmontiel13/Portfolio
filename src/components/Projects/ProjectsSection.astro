---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import ProjectsBgLeft from "./ProjectsBgLeft.astro";
import ProjectsBgRight from "./ProjectsBgRight.astro";

const projects = await getCollection("projects");
---

<section class="projects" id="proyectos">
  <div 
      class="absolute top-0 left-0 -z-10 h-125 w-125 rounded-full 
        bg-[radial-gradient(circle_farthest-side,rgba(59,130,246,0.15),transparent)] 
        blur-3xl md:h-200 md:w-200 -translate-x-1/4 -translate-y-1/4"
></div>
 
  <ProjectsBgLeft />
  <ProjectsBgRight />
  
  <h2>Proyectos / Aportaciones</h2>

  <div class="content-object">
    <div class="carousel-viewport-projects">
      <div class="track carousel-track-horizontal" id="project-track">
        {
          projects.map((project) => (
            <div class="carousel-slide">
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                image1={project.data.image1}
                image2={project.data.image2}
                github={project.data.github}
                tech={project.data.tech}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
  <div class="dots" id="project-dots">
    {
      projects.map((_, i) => (
        <span class={`dot ${i === 0 ? "active" : ""}`} data-index={i} />
      ))
    }
  </div>
</section>

<script>
  const track = document.getElementById("project-track");
  const dots = document.querySelectorAll("#project-dots .dot");

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const index = parseInt(dot.getAttribute("data-index") || "0");
      if (track) track.style.transform = `translateX(-${index * 100}%)`;

      dots.forEach((d) => d.classList.remove("active"));
      dot.classList.add("active");
    });
  });
</script>

<style>
  .projects {
    position: relative;
    width: 100%;
    max-width: 1440px;
    margin: clamp(80px, 15vw, 150px) auto 0;
    padding: 0 clamp(1rem, 5vw, 3rem);
    box-sizing: border-box;
  }

  .projects h2 {
    text-align: center;
    margin-bottom: clamp(32px, 8vw, 60px);
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -1px;
    background: linear-gradient(to bottom, #fff, #999);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.2;
    z-index: 2;
    position: relative;
  }

  .content-object {
    position: relative;
    z-index: 1;
  }
</style>
