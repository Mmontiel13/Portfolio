---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import ProjectsBgLeft from "./ProjectsBgLeft.astro";
import ProjectsBgRight from "./ProjectsBgRight.astro";

const projects = await getCollection("projects");
---

<section class="projects" id="proyectos">
  <ProjectsBgLeft />
  <ProjectsBgRight />
  <h2>Proyectos Destacados / Aportaciones</h2>

  <div class="content-object">
    <div class="carousel-viewport-projects">
      <div class="track carousel-track-horizontal" id="project-track">
        {
          projects.map((project) => (
            <div class="carousel-slide">
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                image1={project.data.image1}
                image2={project.data.image2}
                github={project.data.github}
                tech={project.data.tech}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
  <div class="dots" id="project-dots">
    {
      projects.map((_, i) => (
        <span class={`dot ${i === 0 ? "active" : ""}`} data-index={i} />
      ))
    }
  </div>
</section>

<script>
  const track = document.getElementById("project-track");
  const dots = document.querySelectorAll("#project-dots .dot");

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const index = parseInt(dot.getAttribute("data-index") || "0");
      if (track) track.style.transform = `translateX(-${index * 100}%)`;

      dots.forEach((d) => d.classList.remove("active"));
      dot.classList.add("active");
    });
  });
</script>

<style>
  .projects {
    position: relative;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 20px;
    padding-right: 20px;
    margin-top: 80px;
    padding-top: 150px;
  }
  .projects h2 {
    text-align: center;
    margin-bottom: 60px;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -1px;
    background: linear-gradient(to bottom, #fff, #999);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
</style>
