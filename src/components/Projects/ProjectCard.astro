---
const { title, description, image1, image2, github, tech } = Astro.props;
---

<div class="project-card-wrapper">
  <div class="project-card">
  <div class="images">

    <img class="img-back" src={image1} />

    {image2 && <img class="img-front" src={image2} />}

  </div>

  <div class="project-info">
    <h1>{title}</h1>

    <p>{description}</p>

    <div class="tech-container">
      {tech && tech.map((item) => (
        <span class="tech-tag">{item}</span>
      ))}
    </div>

    <div class="actions">
      {github ? (
        <a class="btn github-link" href={github} target="_blank" rel="noopener noreferrer">
          <i class="fa-brands fa-github fa-lg"></i> Github
        </a>
      ) : (
        <span class="private-badge">
          <i class="fa-solid fa-lock"></i> Github
        </span>
      )}
    </div>
  </div>
  </div>
</div>

<style>
  .project-card-wrapper {
    
    padding: clamp(20px, 5vw, 40px);
    width: 100%;
    box-sizing: border-box;
    scroll-snap-align: center;
    scroll-snap-stop: always;
    flex-shrink: 0;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(12px, 3vw, 20px);
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: 0;
    overflow: hidden;
  }

  @media (min-width: 600px) {
    .project-card {
      flex-direction: column;
      align-items: center;
      gap: clamp(30px, 8vw, 100px);
      max-width: 100%;
    }
  }

  @media (min-width: 1024px) {
    .project-card {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(30px, 8vw, 100px);
      max-width: 100%;
    }
  }
  

  .images {
    position: relative;
    width: 90%;
    max-width: clamp(250px, 80vw, 420px);
    flex-shrink: 0;
    margin-top: clamp(5px, 3vw, 10px);
  }

  .img-back {
    width: clamp(150px, 50vw, 100%);
    border-radius: clamp(12px, 3vw, 18px);
    box-shadow: 0 clamp(6px, 2vw, 10px) clamp(20px, 5vw, 30px) rgba(0,0,0,.8);
  }

  .img-front {
    position: absolute;
    bottom: clamp(-20px, -5vw, -40px);
    right: clamp(-10px, -5vw, -40px);
    width: clamp(150px, 50vw, 100%);
    border-radius: clamp(12px, 3vw, 18px);
    box-shadow: 0 clamp(6px, 2vw, 10px) clamp(20px, 5vw, 30px) rgba(0,0,0,.8);
  }

  .project-info {
    flex: 1;
    max-width: 100%;
    text-align: left;
    padding-bottom: 0;
    padding-top: 20px;
  }

  @media (min-width: 768px) {
    .project-info {
      max-width: clamp(300px, 60vw, 450px);
    }
  }

  h1 {
    font-size: clamp(18px, 5vw, 26px);
    margin-bottom: clamp(12px, 3vw, 20px);
    font-weight: 700;
    text-align: left;
    line-height: 1.2;
  }

  p {
    opacity: 0.8;
    margin-top: clamp(12px, 3vw, 20px);
    margin-bottom: clamp(16px, 3vw, 25px);
    font-size: clamp(13px, 3vw, 15px);
    line-height: 1.6;
  }

  .tech-container {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(8px, 2vw, 12px);
    margin-bottom: clamp(20px, 4vw, 30px);
  }

  .tech-tag {
    font-size: clamp(11px, 2vw, 12px);
    padding: clamp(3px, 1vw, 4px) clamp(8px, 2vw, 12px);
    border-radius: 999px;
    background: rgba(217, 217, 217, 0.1);
    color: rgba(217, 217, 217, 0.8);
    border: 1px solid rgba(217, 217, 217, 0.2);
    font-weight: 500;
  }

  .private-badge {
    font-size: clamp(11px, 2vw, 13px);
    color: rgba(217, 217, 217, 0.4);
    font-style: italic;
    display: flex;
    align-items: center;
    gap: 8px;
    padding-left: 10px;
  }

  .actions {
    margin-top: clamp(8px, 2vw, 10px);
    margin-bottom: clamp(12px, 3vw, 20px);
  }

  .private-badge i {
    font-size: clamp(10px, 2vw, 12px);
  }
</style>
