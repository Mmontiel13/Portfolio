---
const { title, description, image1, image2, github, tech } = Astro.props;
---

<div class="project-card">
  <div class="images">

    <img class="img-back" src={image1} />

    {image2 && <img class="img-front" src={image2} />}

  </div>

  <div class="project-info">
    <h1>{title}</h1>

    <p>{description}</p>

    <div class="tech-container">
      {tech && tech.map((item) => (
        <span class="tech-tag">{item}</span>
      ))}
    </div>

    <div class="actions">
      {github ? (
        <a class="btn github-link" href={github} target="_blank" rel="noopener noreferrer">
          <i class="fa-brands fa-github fa-lg"></i> Github
        </a>
      ) : (
        <span class="private-badge">
          <i class="fa-solid fa-lock"></i> Github
        </span>
      )}
    </div>
  </div>
</div>

<style>
  .project-card {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 100px;
    width: 90%;
    height: 100%;
    
    box-sizing: border-box;
  }

  .images{
  position:relative;
  width:420px;
  flex-shrink: 0;
  margin-top: 20px;
}

.img-back{
  width:100%;
  border-radius:18px;
  box-shadow:0 10px 30px rgba(0,0,0,.8);
}

.img-front{
  position:absolute;
  bottom:-40px;
  right:-40px;

  width:100%;

  border-radius:18px;

  box-shadow:0 10px 30px rgba(0,0,0,.8);
}

  .project-info {
    flex: 1;
    max-width: 450px;
    text-align: left;
    padding-bottom: 2;
  }

  h1{
    font-size:26px;
    margin-bottom:20px;
    font-weight: 700;
    text-align: left;
  }

  p {
    opacity: 0.8;
    margin-top: 20px;
    margin-bottom: 25px;
  }

  .tech-container {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 30px;
  }

  .tech-tag {
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(217, 217, 217, 0.1);
    color: rgba(217, 217, 217, 0.8);
    border: 1px solid rgba(217, 217, 217, 0.2);
    font-weight: 500;
  }

  .private-badge {
    font-size: 13px;
    color: rgba(217, 217, 217, 0.4);
    font-style: italic;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0;
  }

  .actions {
    margin-top: 10px;
    margin-bottom: 20px;
  }

  .private-badge i {
    font-size: 12px;
  }
</style>
