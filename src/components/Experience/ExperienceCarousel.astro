---
import { getCollection } from "astro:content"
import ExperienceCard from "./ExperienceCard.astro"
const experience = await getCollection("experience")
---

<div class="carousel">
  <div class="carousel-viewport-experience ">
    <p class="carousel-title">Experiencia Laboral</p>
    <div class="content-object">
      <div class="track carousel-track-horizontal" id="exp-track">
        {experience.map(exp => (
          <div class="carousel-slide">
            <ExperienceCard
              company={exp.data.company}
              role={exp.data.role}
              description={exp.data.description}
              date={exp.data.date}
              logo={exp.data.logo}
            />
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="dots" id="exp-dots">
        {experience.map((_, i) => (
          <span class={`dot ${i === 0 ? 'active' : ''}`} data-index={i}></span>
        ))}
      </div>
</div>

<script>
  const track = document.getElementById('exp-track');
  const dots = document.querySelectorAll('#exp-dots .dot');

  // Function to update active dot based on scroll position
  function updateActiveDot() {
    if (!track) return;
    
    const slides = track.querySelectorAll('.carousel-slide');
    const trackRect = track.getBoundingClientRect();
    const trackCenter = trackRect.left + trackRect.width / 2;
    
    let closestIndex = 0;
    let minDistance = Infinity;
    
    slides.forEach((slide, index) => {
      const slideRect = slide.getBoundingClientRect();
      const slideCenter = slideRect.left + slideRect.width / 2;
      const distance = Math.abs(trackCenter - slideCenter);
      
      if (distance < minDistance) {
        minDistance = distance;
        closestIndex = index;
      }
    });
    
    dots.forEach((d, i) => {
      d.classList.toggle('active', i === closestIndex);
    });
  }

  // Intersection Observer for more precise detection
  const observerOptions = {
    root: track,
    threshold: 0.5,
    rootMargin: '0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const index = Array.from(track.querySelectorAll('.carousel-slide')).indexOf(entry.target);
        dots.forEach((d, i) => {
          d.classList.toggle('active', i === index);
        });
      }
    });
  }, observerOptions);

  // Observe all slides
  track?.querySelectorAll('.carousel-slide').forEach(slide => {
    observer.observe(slide);
  });

  // Fallback scroll event listener
  track?.addEventListener('scroll', updateActiveDot, { passive: true });

  // Dot click handlers
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index') || "0");
      const slide = track?.querySelectorAll('.carousel-slide')[index];
      if (slide) {
        slide.scrollIntoView({ 
          behavior: 'smooth', 
          block: 'nearest', 
          inline: 'center' 
        });
      }
    });
  });
</script>

<style>
.carousel {
  width: 100%;
  max-width: clamp(280px, 90vw, 350px);
  position: relative;
  margin: 0 auto;
}

.track {
  display: flex;
}

.carousel-title {
  color: #fff;
  font-weight: bold;
  opacity: 0.9;
  margin-bottom: clamp(40px, 8vw, 60px);
  padding-bottom: clamp(12px, 3vw, 20px);
  text-align: center;
  font-size: clamp(14px, 4vw, 18px);
}

@media (min-width: 640px) {
  .carousel {
    max-width: clamp(300px, 85vw, 350px);
  }
}

@media (min-width: 1024px) {
  .carousel {
    max-width: 350px;
  }
}
</style>