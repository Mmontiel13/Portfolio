---
import WorkAvailability from "../WorkAvailability.astro";
---

<div class="intro-card content-object">

  <div class="intro-header">

    <img src="/avatar.jpg" alt="avatar">

    <div>
      <h4>Ingeniería en Tecnologías de la Información</h4>
      
    </div>

  </div>
  <WorkAvailability isAvailable={true} />
  <p>
    Estudiante de la <span>BUAP,</span><b> Puebla, México.</b> 
  </p>

  

</div>  

<style>

.intro-card{
  width: 100%;
  max-width: clamp(280px, 90vw, 350px);
  padding: clamp(16px, 4vw, 22px);
  margin-top: clamp(10px, 10vw, 10px);
  margin-left: 30px;
  margin-right: auto;
}

.intro-header{
  display: flex;
  gap: clamp(10px, 3vw, 15px);
  align-items: center;
  margin-bottom: clamp(8px, 2vw, 10px);
}

img{
  width: clamp(30px, 8vw, 35px);
  height: clamp(30px, 8vw, 35px);
  border-radius: 50%;
  flex-shrink: 0;
}

h4{
  font-size: clamp(12px, 3vw, 14px);
  line-height: 1.3;
}

span{
  font-size: clamp(11px, 2.5vw, 12px);
  opacity: .7;
}

p{
  font-size: clamp(12px, 2.5vw, 13px);
  opacity: .8;
  line-height: 1.5;
}

a{
  font-size: clamp(12px, 2.5vw, 13px);
}

@media (min-width: 1024px) {
  .intro-card {
    max-width: 350px;
  }
}

</style>