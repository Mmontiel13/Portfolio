---
import HeroCard from "./HeroCard.astro"
import ExperienceCarousel from "../Experience/ExperienceCarousel.astro"
import IntroCard from "./IntroCard.astro"
import HeroBg from "./HeroBg.astro"
---

<section class="hero" id="inicio">
  <HeroBg />
  <div class="hero-container">

    <div class="hero-main">
      <HeroCard />
    </div>

    <div class="hero-experience">
      <ExperienceCarousel />
    </div>

    <div class="hero-intro">
      <IntroCard />
    </div>

  </div>

</section>

<style>

.hero {
  position: relative;
  max-width: auto;
  margin: auto;
  min-height: 500px;
  
}

.hero-container{
  display:grid;
  grid-template-columns: 1.2fr 1fr;
  grid-template-rows: auto auto;
  gap:40px;

  grid-template-areas:
    "hero experience"
    "intro experience";

  padding-top: 160px;
  padding-bottom: 120px;
}

.hero-main{
  grid-area: hero;
  margin-left: 80px;
}

.hero-experience{
  grid-area: experience;
  display:flex;
  justify-content:flex-end;
  margin-right: 60px;
}

.hero-intro{
  grid-area: intro;
  margin-left: 120px;
}

</style>