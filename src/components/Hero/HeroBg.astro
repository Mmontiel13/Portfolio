<style>
    .hero-bg-wrapper {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: auto;
        width: 100%;
        height: 100%;
    }
    
    .svg-container {
        position: absolute;
        width: 100%;
        max-width: clamp(300px, 80vw, 800px);
        height: auto;
        aspect-ratio: 687 / 615;
    }

    .code-pos {
        left: clamp(48%, 10vw, 27%);
        transform: translateX(-50%) rotate(-10deg) scaleX(clamp(0.6, 0.8, 1)) scaleY(clamp(0.6, 0.8, 1));
        top: clamp(100px, 8vh, 15%);
        opacity: clamp(0.4, 0.5, 0.7);
    }

    @media (min-width: 640px) {
        .code-pos {
            left: clamp(10px, 20vw, 10%);
            transform: translateX(0) rotate(-10deg) scaleX(1) scaleY(1);
            opacity: 0.6;
        }
    }

    @media (min-width: 780px) {
        .code-pos {
            left: clamp(20px, 10%, 400px);
            opacity: 0.7;
        }
    }

    @media (min-width: 1024px) {
        .code-pos {
            left: clamp(20px, 22%, 400px);
            opacity: 0.7;
        }
    }

    .glow-purple {
        position: absolute;
        inset: 0;
        background: rgba(147, 51, 234, 0.15);
        filter: blur(clamp(50px, 12vw, 100px));
        border-radius: 9999px;
        opacity: clamp(0.5, 0.7, 1);
    }

    .code {
        width: 100%;
        height: auto;
    }

</style>

<script>
    import { createDraggable, spring } from 'animejs';
    createDraggable('.code', {
        container: [0,0,0,0],
        releaseEase: spring({ bounce: .5 })
    });

    function startAnimation() {
        const lines = document.querySelectorAll(".code-line");

        function run() {
            const count = Math.floor(Math.random() * 2) + 2;

            const shuffled = Array.from(lines).sort(() => Math.random() - 0.8);
            const selected = shuffled.slice(0, count);

            selected.forEach(line => {
            line.classList.add("flash");

            setTimeout(() => {
                line.classList.remove("flash");
            }, 500);
            });

            setTimeout(run, Math.random() * 1500 + 500);
        }

        run();
        }

        document.addEventListener("DOMContentLoaded", startAnimation);
</script>
