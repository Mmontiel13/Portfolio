<style>
    .hero-bg-wrapper {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: auto;
    }
    
    .svg-container {
        position: absolute;
        width: 800px;
    }

    .code-pos {
        left: 27%;
        top: 15%;
        transform: rotate(-10deg);
        opacity: 0.7;
    }

    .glow-purple {
        position: absolute;
        inset: 0;
        background: rgba(147, 51, 234, 0.15);
        filter: blur(100px);
        border-radius: 9999px;
    }

    .code {
        width: 100%;
        height: auto;
    }

</style>

<script>
    import { createDraggable, spring } from 'animejs';
    createDraggable('.code', {
        container: [0,0,0,0],
        releaseEase: spring({ bounce: .5 })
    });
</script>
