<style>
    .motion-container {
        width: 100%;
        max-width: 600px;
        margin: auto;
        filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.4));
    }
    svg {
        display: block;
        width: 100%;
        height: auto;
    }

    .code-line {
        transition: filter 0.4s ease;
    }

    .flash {
        filter: brightness(2.5) drop-shadow(0 0 12px #fff);
    }
</style>


<script>
    import { utils, createDraggable, spring } from 'animejs';
    const [ $code ] = utils.$('.code');
    const [ $smallCode ] = utils.$('.small-code');
    const [ $browser ] = utils.$('.browser');

    createDraggable('.code', {
        container: [0,0,0,0],
        releaseEase: spring({ bounce: .5 })
    });

    createDraggable('.small-code', {
        container: [0,0,0,0],
        releaseEase: spring({ bounce: .5 })
    });

    createDraggable('.browser', {
        container: [0,0,0,0],
        releaseEase: spring({ bounce: .5 })
    });

    function startAnimation() {
        const lines = document.querySelectorAll(".code-line");

        function run() {
            const count = Math.floor(Math.random() * 3) + 2;

            const shuffled = Array.from(lines).sort(() => Math.random() - 0.5);
            const selected = shuffled.slice(0, count);

            selected.forEach(line => {
            line.classList.add("flash");

            setTimeout(() => {
                line.classList.remove("flash");
            }, 400);
            });

            setTimeout(run, Math.random() * 1500 + 500);
        }

        run();
        }

        document.addEventListener("DOMContentLoaded", startAnimation);
</script>
