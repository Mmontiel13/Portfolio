---
import BgContact from "./BgContact.astro"
---
<section class="contact" id="contacto">
  <div class="section-gradient"></div>

  <div class="content-wrapper">
    <h2>Contactame</h2>

    <div class="contact-grid">
      <div class="left">
        <h4>Medios de comunicación</h4>
        <div class="links">
            <a href="mailto:marcmontiel98@gmail.com?Subject=Me interesa contactarte!">Enviar e-mail <i class="fa-solid fa-paper-plane"></i></a>
            <div class="social-icons">
                <a href="https://github.com/Mmontiel13"><i class="fa-brands fa-github fa-lg"></i></a>
                <a href="https://www.linkedin.com/in/devmontiels/"><i class="fa-brands fa-linkedin fa-lg"></i></a>
            </div>
        </div>
      </div>

      <div class="center">
        <BgContact />
        <div class="form-overlay">
           <slot />
        </div>
      </div>

      <div class="right">
        <h4>Otras Actividades</h4>
        <p>Diseño UI, contribuciones open source</p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding-bottom: clamp(50px, 12vw, 50px);
    margin-top: clamp(100px, 20vw, 250px);
    color: white;
    overflow-x: hidden;
  }

  .section-gradient {
    position: absolute;
    width: 100%;
    inset: 0;
    background: linear-gradient(0deg, rgba(66, 51, 234, 0.185) 0%, rgba(18, 12, 39, 0) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .content-wrapper {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 3rem);
    box-sizing: border-box;
  }

  .contact h2 {
    text-align: center;
    margin-bottom: clamp(32px, 8vw, 60px);
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -1px;
    background: linear-gradient(to bottom, #fff, #999);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.2;
  }

  .contact-grid {
    display: grid;
    width: 100%;
    max-width: 100%;
    grid-template-columns: minmax(clamp(40px, 8vw, 80px), 10%) minmax(0, 80%) minmax(clamp(40px, 8vw, 80px), 10%);
    gap: clamp(16px, 4vw, 32px);
    align-items: start;
    justify-items: stretch;
    overflow: hidden;
    min-width: 0;
    box-sizing: border-box;
  }

  /* Mobile stack */
  @media (max-width: 767px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: clamp(18px, 5vw, 32px);
    }

    .contact-grid > .left,
    .contact-grid > .center,
    .contact-grid > .right {
      width: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .center {
      order: -1;
      margin-bottom: clamp(20px, 5vw, 30px);
    }
  }

  .center {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .form-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    display: flex;
    justify-content: center;
    z-index: 5;
  }

  /* Estilos para laterales */
  .left, .right {
    text-align: left;
  }

  @media (min-width: 768px) {
    .left, .right {
      text-align: center;
    }
  }

  .left h4, .right h4 {
    margin-bottom: clamp(10px, 2vw, 15px);
    font-size: clamp(0.75rem, 2vw, 0.9rem);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: clamp(10px, 2vw, 15px);
  }

  .links a {
    color: rgba(217, 217, 217, 0.9);
    text-decoration: none;
    font-size: clamp(12px, 2.5vw, 14px);
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: clamp(6px, 1vw, 8px);
  }

  .links a:hover {
    color: rgba(217, 217, 217, 1);
  }

  .social-icons {
    display: flex;
    gap: clamp(8px, 2vw, 12px);
    margin-top: clamp(12px, 2vw, 15px);
    flex-wrap: wrap;
  }

  .social-icons a {
    transition: transform 0.2s ease, color 0.2s ease;
    color: rgba(217, 217, 217, 0.8);
  }

  .social-icons a:hover {
    transform: scale(1.2);
    color: rgba(217, 217, 217, 1);
  }

  .right p {
    font-size: clamp(12px, 2.5vw, 14px);
    color: rgba(255, 255, 255, 0.7);
    margin-top: clamp(8px, 2vw, 12px);
  }

  /* Mobile optimization */
  @media (max-width: 767px) {
    .contact-grid {
      order-direction: column;
    }

    .center {
      order: -1;
      margin-bottom: clamp(20px, 5vw, 30px);
    }
  }
</style>